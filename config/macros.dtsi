macro_disp_right: macro_disp_right{
compatible = "zmk,behavior-macro";
label = "macro_disp_right";
#binding-cells = <0>;
bindings = <&mt LCTRL undefined>, <&mt LEFT_GUI RIGHT>;
};
macro_disp_left: macro_disp_left{
compatible = "zmk,behavior-macro";
label = "macro_disp_left";
#binding-cells = <0>;
bindings = <&mt LCTRL undefined>, <&mt LEFT_GUI LEFT>;
};